# Supabase — get from: https://supabase.com/dashboard/project/[your-project]/settings/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# VAPID public key for Web Push notifications (safe to expose)
# Generate a key pair with: node -e "require('web-push').generateVAPIDKeys().then(k => console.log(JSON.stringify(k)))"
# Set the private key as a Supabase secret: supabase secrets set VAPID_PRIVATE_KEY=...
VITE_VAPID_PUBLIC_KEY=

# Google Maps API key (client-side — restrict by HTTP referrer in Cloud Console)
# Enable: Maps JavaScript API, Geocoding API, Places API, Static Maps API
VITE_GOOGLE_MAPS_API_KEY=

# AI API keys are NOT here.
# They live in Supabase Edge Function secrets only.
# Set with: supabase secrets set ANTHROPIC_API_KEY=sk-ant-...
# Set with: supabase secrets set GOOGLE_AI_API_KEY=AIza...
